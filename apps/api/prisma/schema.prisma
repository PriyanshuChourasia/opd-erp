generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String         @id @default(uuid())
  username         String         @unique
  firstName        String
  middleName       String?
  lastName         String
  gender           String?        // MALE | FEMALE | OTHER
  dateOfBirth      DateTime?
  email            String         @unique
  mobileNumber     String?
  countryCode      String         @default("+91")
  profilePhotoUrl  String?
  qualification    String?
  password         String
  isActive         Boolean        @default(true)
  roleId           String
  userableType     String?        // "Doctor" | "Patient" | "Nurse" | "Receptionist" | "Pharmacist" | "LabStaff"
  userableId       String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  role             Role           @relation(fields: [roleId], references: [id])
  refreshTokens    RefreshToken[]
  createdAppointments Appointment[]

  @@index([userableType, userableId])
}

model Role {
  id          String           @id @default(uuid())
  name        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  users       User[]
  rolePermissions RolePermission[]
}

model Permission {
  id        String           @id @default(uuid())
  resource  String
  action    String           // "read" | "create" | "update" | "delete" | "manage"
  name      String           // Display name e.g. "Read Patients"
  createdAt DateTime         @default(now())
  rolePermissions RolePermission[]

  @@unique([resource, action])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Allergy Catalog ────────────────────────────────────────

enum AllergySeverity {
  MILD
  MODERATE
  SEVERE
  LIFE_THREATENING
}

enum AllergyCategory {
  DRUG
  FOOD
  ENVIRONMENTAL
  OTHER
}

model Allergy {
  id        String           @id @default(uuid())
  name      String           @unique
  description String?
  severity  AllergySeverity  @default(MODERATE)
  category  AllergyCategory  @default(OTHER)
  isActive  Boolean          @default(true)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  patientAllergies PatientAllergy[]
}

model PatientAllergy {
  id              String           @id @default(uuid())
  patientId       String
  allergyId       String
  notes           String?
  severityOverride AllergySeverity?
  createdAt       DateTime         @default(now())
  patient         Patient          @relation(fields: [patientId], references: [id], onDelete: Cascade)
  allergy         Allergy          @relation(fields: [allergyId], references: [id], onDelete: Cascade)

  @@unique([patientId, allergyId])
  @@index([patientId])
  @@index([allergyId])
}

// ─── Diagnosis Catalog ──────────────────────────────────────

model Diagnosis {
  id          String   @id @default(uuid())
  name        String   @unique
  icdCode     String?
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─── Clinical Models ──────────────────────────────────────────

model Patient {
  id               String   @id @default(uuid())
  name             String
  phone            String   @unique
  email            String?
  dateOfBirth      DateTime?
  gender           String?
  bloodGroup       String?
  address          String?
  emergencyContact String?
  allergies        String[]
  isFollowUp       Boolean  @default(false)
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  appointments   Appointment[]
  queueEntries   QueueEntry[]
  prescriptions  Prescription[]
  labOrders      LabOrder[]
  radiologyOrders RadiologyOrder[]
  procedureOrders ProcedureOrder[]
  bills          Bill[]
  patientAllergies PatientAllergy[]
}

model Doctor {
  id                       String   @id @default(uuid())
  qualification            String?
  specialization           String?
  medicalRegistrationNo   String   @unique
  medicalCouncil           String?
  registrationYear         Int?
  yearsOfExperience        Int?
  consultationFee          Int      @default(0)
  consultationMode         String   @default("OFFLINE") // OFFLINE | ONLINE | BOTH
  signature                String?
  registrationCertificateUrl String?
  degreeCertificateUrl     String?
  governmentIdUrl          String?
  verificationStatus       String   @default("PENDING") // PENDING | VERIFIED | REJECTED | SUSPENDED
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  appointments    Appointment[]
  queueEntries    QueueEntry[]
  prescriptions   Prescription[]
  labOrders       LabOrder[]
  radiologyOrders RadiologyOrder[]
  procedureOrders ProcedureOrder[]

  @@index([verificationStatus])
  @@index([specialization])
}

model QueueEntry {
  id            String       @id @default(uuid())
  tokenNumber   String
  patientId     String
  doctorId      String
  status        String       @default("WAITING") // WAITING | IN_PROGRESS | COMPLETED | SKIPPED | NO_SHOW
  queueDate     DateTime     @default(now())
  checkedInAt   DateTime?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  patient       Patient      @relation(fields: [patientId], references: [id])
  doctor        Doctor       @relation(fields: [doctorId], references: [id])
  appointmentId String?      @unique // Set when this queue entry has a linked appointment, used for invoicing
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])

  @@unique([doctorId, queueDate, tokenNumber])
  @@index([doctorId, queueDate])
  @@index([patientId])
}

model Appointment {
  id          String   @id @default(uuid())
  patientId   String
  doctorId    String
  createdById String?
  date        DateTime
  type        String   @default("CONSULTATION") // WALK_IN | CONSULTATION | SPECIALIST | EMERGENCY | FOLLOW_UP | TELECONSULTATION
  status      String   @default("SCHEDULED") // SCHEDULED | CONFIRMED | CHECKED_IN | IN_PROGRESS | COMPLETED | CANCELLED | NO_SHOW
  tokenNumber String?
  fee         Int      @default(0)
  registrationFee Int  @default(0) // Charged once per patient, on their first-ever appointment
  reasonForVisit String? // Chief complaint / why the patient is coming in
  notes       String?
  cancellationReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctor      Doctor   @relation(fields: [doctorId], references: [id])
  createdBy   User?    @relation(fields: [createdById], references: [id])
  bill        Bill?
  queueEntry  QueueEntry?

  @@index([patientId])
  @@index([doctorId])
  @@index([createdById])
  @@index([date])
}

// ─── Medicine Catalog ────────────────────────────────────────

model Medicine {
  id          String   @id @default(uuid())
  name        String
  genericName String?
  brandName   String?
  category    String?  // TABLET | CAPSULE | SYRUP | INJECTION | CREAM | DROPS | INHALER | OTHER
  strength    String?  // e.g. "500mg"
  unit        String   @default("tablet") // tablet, ml, mg, etc.
  price       Int      @default(0) // in rupees
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([name])
  @@index([genericName])
}

// ─── Prescriptions ───────────────────────────────────────────

model Prescription {
  id          String              @id @default(uuid())
  patientId   String
  doctorId    String
  diagnosis   String?
  notes       String?
  status      String              @default("ACTIVE") // ACTIVE | DISPENSED | CANCELLED
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  patient     Patient             @relation(fields: [patientId], references: [id])
  doctor      Doctor              @relation(fields: [doctorId], references: [id])
  items       PrescriptionItem[]
  dispensings Dispensing[]

  @@index([patientId])
  @@index([doctorId])
}

model PrescriptionItem {
  id             String       @id @default(uuid())
  prescriptionId String
  medicineId     String
  medicineName   String       // Snapshot of medicine name at time of prescribing
  dosage         String       // e.g. "1-0-1"
  duration       String?      // e.g. "7 days"
  instructions   String?      // e.g. "After meals"
  quantity       Int
  refills        Int          @default(0)
  createdAt      DateTime     @default(now())
  prescription   Prescription @relation(fields: [prescriptionId], references: [id], onDelete: Cascade)

  @@index([prescriptionId])
}

// ─── Lab Orders ──────────────────────────────────────────────

model LabOrder {
  id          String   @id @default(uuid())
  patientId   String
  doctorId    String
  testName    String   // e.g. "Complete Blood Count"
  category    String?  // HEMATOLOGY | BIOCHEMISTRY | MICROBIOLOGY | PATHOLOGY | OTHER
  notes       String?
  status      String   @default("ORDERED") // ORDERED | COLLECTED | PROCESSING | COMPLETED | CANCELLED
  result      String?  // Result text or JSON for structured results
  resultDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctor      Doctor   @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
  @@index([status])
}

// ─── Radiology Orders ────────────────────────────────────────

model RadiologyOrder {
  id          String   @id @default(uuid())
  patientId   String
  doctorId    String
  studyName   String   // e.g. "Chest X-Ray PA View"
  category    String?  // XRAY | CT | MRI | ULTRASOUND | MAMMOGRAM | FLUOROSCOPY | OTHER
  notes       String?
  status      String   @default("ORDERED") // ORDERED | SCHEDULED | COMPLETED | CANCELLED
  result      String?  // Free-text or structured report
  resultDate  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patient     Patient  @relation(fields: [patientId], references: [id])
  doctor      Doctor   @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
}

// ─── Procedure Orders ────────────────────────────────────────

model ProcedureOrder {
  id           String   @id @default(uuid())
  patientId    String
  doctorId     String
  procedureName String  // e.g. "ECG", "Pulmonary Function Test"
  category     String?  // DIAGNOSTIC | THERAPEUTIC | SURGICAL | PREVENTIVE | OTHER
  notes        String?
  status       String   @default("ORDERED") // ORDERED | SCHEDULED | COMPLETED | CANCELLED
  result       String?
  resultDate   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  patient      Patient  @relation(fields: [patientId], references: [id])
  doctor       Doctor   @relation(fields: [doctorId], references: [id])

  @@index([patientId])
  @@index([doctorId])
}

// ─── Billing ─────────────────────────────────────────────────

model Bill {
  id            String       @id @default(uuid())
  patientId     String?
  appointmentId String?      @unique // Set when this invoice originated from an appointment checkout
  invoiceNo     String       @unique // Human-readable invoice number
  subtotal      Int          @default(0)
  discount      Int          @default(0)
  tax           Int          @default(0)
  total         Int          @default(0)
  paymentMethod String       @default("CASH") // CASH | CARD | UPI
  status        String       @default("PENDING") // PENDING | PAID | PARTIAL | REFUNDED | CANCELLED
  notes         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  patient       Patient?     @relation(fields: [patientId], references: [id])
  appointment   Appointment? @relation(fields: [appointmentId], references: [id])
  items         BillItem[]

  @@index([patientId])
  @@index([invoiceNo])
}

model BillItem {
  id        String @id @default(uuid())
  billId    String
  itemType  String // CONSULTATION | MEDICINE | LAB | RADIOLOGY | PROCEDURE | OTHER
  itemId    String? // Reference ID to the source (appointment, prescription, etc.)
  itemName  String
  quantity  Int    @default(1)
  unitPrice Int
  amount    Int
  createdAt DateTime @default(now())
  bill      Bill   @relation(fields: [billId], references: [id], onDelete: Cascade)

  @@index([billId])
}

// ─── Dispensing ──────────────────────────────────────────────

model Dispensing {
  id             String       @id @default(uuid())
  prescriptionId String
  medicineId     String
  medicineName   String       // Snapshot of medicine name
  quantity       Int
  batchNo        String?
  expiryDate     DateTime?
  notes          String?
  dispensedAt    DateTime     @default(now())
  dispensedBy    String?
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])

  @@index([prescriptionId])
  @@index([medicineId])
}

// ─── Shift ───────────────────────────────────────────────────

model Shift {
  id             String              @id @default(uuid())
  name           String
  code           String              @unique // e.g. "M", "E", "N", "OPD_EVE"
  startTime      String              // "HH:mm"
  endTime        String              // "HH:mm"
  breakStartTime String?             // "HH:mm"
  breakEndTime   String?             // "HH:mm"
  isOvernight    Boolean             @default(false)
  description    String?
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  schedules      EmployeeSchedule[]
}

// ─── Employee Schedule (generic, replaces DoctorSchedule) ────

model EmployeeSchedule {
  id          String   @id @default(uuid())
  dayOfWeek   Int      // 0=Monday … 6=Sunday (see DayOfWeek enum)
  startTime   String   // "HH:mm"
  endTime     String   // "HH:mm"
  shiftId     String?
  employeeSchedulableType  String   // "Doctor" | "Nurse" | "Receptionist" | "Pharmacist" | "LabStaff"
  employeeSchedulableId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  shift       Shift?   @relation(fields: [shiftId], references: [id], onDelete: SetNull)

  @@index([employeeSchedulableType, employeeSchedulableId, dayOfWeek], map: "emp_sched_type_id_dow")
  @@index([employeeSchedulableType, employeeSchedulableId], map: "emp_sched_type_id")
}

// ─── Address (polymorphic) ───────────────────────────────────
// Reusable for Users, Doctors, Clinics, Hospitals, Organisations, etc.

model Address {
  id              String   @id @default(uuid())
  addressType     String   // CLINIC | HOME | BILLING | OTHER
  addressLine1    String
  addressLine2    String?
  landmark        String?
  city            String?
  district        String?
  state           String?
  country         String   @default("India")
  postalCode      String?
  latitude        Float?
  longitude       Float?
  isPrimary       Boolean  @default(false)
  isActive        Boolean  @default(true)
  addressableType String   // "User" | "Doctor" | "Organisation" | "Clinic" | "Hospital"
  addressableId   String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([addressableType, addressableId])
  @@index([addressableType, addressableId, isPrimary])
}

// ─── Document (polymorphic) ──────────────────────────────────
// Reusable for Patient photos, Doctor certificates, prescriptions, etc.

model Document {
  id               String   @id @default(uuid())
  documentType     String   // PROFILE_PHOTO | MEDICAL_RECORD | CERTIFICATE | PRESCRIPTION | LAB_REPORT | OTHER
  fileName         String
  originalName     String
  mimeType         String
  fileSize         Int      // bytes
  filePath         String   // relative path to stored file
  caption          String?
  isPrimary        Boolean  @default(false)
  isActive         Boolean  @default(true)
  documentableType String   // "Patient" | "Doctor" | "Prescription" | "Appointment" | etc.
  documentableId   String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([documentableType, documentableId])
  @@index([documentableType, documentableId, isPrimary])
}

// ─── Organisation ────────────────────────────────────────────

model Organisation {
  id                 String   @id @default(uuid())
  name               String
  address            String?
  phone              String?
  email              String?
  website            String?
  registrationNumber String?
  registrationFee    Int      @default(100) // Flat fee charged once per patient, on their first-ever appointment
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}
